# ==========================================================================
# Variaveis de ambiente compartilhadas pelo docker-compose
# ==========================================================================

# ---- MinIO (S3 local) ----
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
AWS_REGION=us-east-1
WAREHOUSE_BUCKET=warehouse

# ---- Kafka ----
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_HOST=localhost:29092

# ---- Iceberg REST ----
ICEBERG_REST_URI=http://iceberg-rest:8181

# ---- Gerador CDC ----
# Quantidade minima e maxima de registros emitidos por segundo
CDC_MIN_RPS=1
CDC_MAX_RPS=3
# Probabilidade (0-1) de um evento ser uma ALTERACAO de algo ja enviado
CDC_UPDATE_RATIO=0.35

# ---- Airflow ----
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
