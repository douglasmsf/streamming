# ==========================================================================
# Exemplo de variaveis de ambiente. Copie para .env e ajuste se necessario.
#   cp .env.example .env      (Linux/macOS)
#   Copy-Item .env.example .env   (Windows)
# Os valores abaixo sao defaults LOCAIS de demonstracao - troque em producao.
# ==========================================================================

# ---- MinIO (S3 local) ----
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
AWS_REGION=us-east-1
WAREHOUSE_BUCKET=warehouse

# ---- Kafka ----
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_HOST=localhost:29092

# ---- Iceberg REST ----
ICEBERG_REST_URI=http://iceberg-rest:8181

# ---- Gerador CDC ----
CDC_MIN_RPS=1
CDC_MAX_RPS=3
CDC_UPDATE_RATIO=0.35

# ---- Airflow ----
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
